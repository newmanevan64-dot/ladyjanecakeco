<script>
// ══════════════════════════════════
//  CART STATE
// ══════════════════════════════════
let cart = [];
let itemId = 0;

const CAKE_FLAVORS = ['Vanilla','Chocolate','Almond','Lemon'];
const MACARON_FLAVORS = ['Vanilla','Triple Chocolate','Strawberries & Cream','Pistachio','Salted Caramel','Piña Colada','Lemon Raspberry','✏️ Custom Flavor...'];

// ── Menu items definition ──
const MENU_ITEMS = {
  // Classic
  'classic-mini7':   { name:'7 Mini Rose Cupcakes', price:20, collection:'Classic', flavors: CAKE_FLAVORS },
  'classic-bq7':     { name:'Bouquet of 7', price:35, collection:'Classic', flavors: CAKE_FLAVORS },
  'classic-bq12':    { name:'Bouquet of 12', price:60, collection:'Classic', flavors: CAKE_FLAVORS },
  'classic-bq19':    { name:'Bouquet of 19', price:95, collection:'Classic', flavors: CAKE_FLAVORS },
  'classic-box6':    { name:'Box of 6', price:30, collection:'Classic', flavors: CAKE_FLAVORS },
  'classic-box12':   { name:'Box of 12', price:60, collection:'Classic', flavors: CAKE_FLAVORS },
  'classic-box18':   { name:'Box of 18', price:90, collection:'Classic', flavors: CAKE_FLAVORS },
  'classic-box24':   { name:'Box of 24', price:120, collection:'Classic', flavors: CAKE_FLAVORS },
  'classic-mini24':  { name:'24 Minis', price:50, collection:'Classic', flavors: CAKE_FLAVORS },
  // Charming
  'charm-bq7':   { name:'Bouquet of 7', price:65, collection:'Charming Florals', flavors: CAKE_FLAVORS },
  'charm-bq12':  { name:'Bouquet of 12', price:110, collection:'Charming Florals', flavors: CAKE_FLAVORS },
  'charm-bq19':  { name:'Bouquet of 19', price:174, collection:'Charming Florals', flavors: CAKE_FLAVORS },
  'charm-box6':  { name:'Box of 6', price:45, collection:'Charming Florals', flavors: CAKE_FLAVORS },
  'charm-box12': { name:'Box of 12', price:90, collection:'Charming Florals', flavors: CAKE_FLAVORS },
  'charm-box18': { name:'Box of 18', price:135, collection:'Charming Florals', flavors: CAKE_FLAVORS },
  'charm-box24': { name:'Box of 24', price:180, collection:'Charming Florals', flavors: CAKE_FLAVORS },
  'charm-mini24':{ name:'24 Minis', price:60, collection:'Charming Florals', flavors: CAKE_FLAVORS },
  // Intricate
  'intr-bq7':   { name:'Bouquet of 7', price:70, collection:'Intricate Florals', flavors: CAKE_FLAVORS },
  'intr-bq12':  { name:'Bouquet of 12', price:120, collection:'Intricate Florals', flavors: CAKE_FLAVORS },
  'intr-bq19':  { name:'Bouquet of 19', price:190, collection:'Intricate Florals', flavors: CAKE_FLAVORS },
  'intr-box6':  { name:'Box of 6', price:55, collection:'Intricate Florals', flavors: CAKE_FLAVORS },
  'intr-box12': { name:'Box of 12', price:100, collection:'Intricate Florals', flavors: CAKE_FLAVORS },
  'intr-box18': { name:'Box of 18', price:165, collection:'Intricate Florals', flavors: CAKE_FLAVORS },
  'intr-box24': { name:'Box of 24', price:220, collection:'Intricate Florals', flavors: CAKE_FLAVORS },
  'intr-mini24':{ name:'24 Minis', price:75, collection:'Intricate Florals', flavors: CAKE_FLAVORS },
  // Macarons
  'mac-6':  { name:'Macarons — Box of 6', price:15, collection:'Macarons', flavors: MACARON_FLAVORS },
  'mac-12': { name:'Macarons — Box of 12', price:30, collection:'Macarons', flavors: MACARON_FLAVORS },
  'mac-30': { name:'Macarons — Full Batch (30–35)', price:70, collection:'Macarons', flavors: MACARON_FLAVORS },
  'tower-4':  { name:'4-Tier Tower (40–45 macarons)', price:120, collection:'Macaron Tower', flavors: MACARON_FLAVORS },
  'tower-5':  { name:'5-Tier Tower (60–65 macarons)', price:180, collection:'Macaron Tower', flavors: MACARON_FLAVORS },
  'tower-6':  { name:'6-Tier Tower (80–90 macarons)', price:240, collection:'Macaron Tower', flavors: MACARON_FLAVORS },
  'tower-7':  { name:'7-Tier Tower (100–110 macarons)', price:300, collection:'Macaron Tower', flavors: MACARON_FLAVORS },
  'tower-8':  { name:'8-Tier Tower (130–140 macarons)', price:390, collection:'Macaron Tower', flavors: MACARON_FLAVORS },
  'tower-9':  { name:'9-Tier Tower (170–180 macarons)', price:500, collection:'Macaron Tower', flavors: MACARON_FLAVORS },
  'tower-10': { name:'10-Tier Tower (205–220 macarons)', price:585, collection:'Macaron Tower', flavors: MACARON_FLAVORS },
  // Add-Ons
  'addon-buttercream': { name:'Flavored Buttercream Upgrade', price:10, collection:'Add-On', flavors:[] },
  'addon-rush':        { name:'Rush Order Fee (< 3 days)', price:20, collection:'Add-On', flavors:[] },
  'addon-gf':          { name:'Gluten-Free Option', price:0, collection:'Add-On', flavors:[] },
};

// ══════════════════════════════════
//  RENDER MENU WITH ATC BUTTONS
// ══════════════════════════════════
function buildFlavorSelect(itemKey) {
  const item = MENU_ITEMS[itemKey];
  const opts = item.flavors.map(f => `<option>${f}</option>`).join('');
  return `<select class="flavor-select" id="flavor-${itemKey}">${opts}</select>`;
}

function buildATCRow(itemKey) {
  const item = MENU_ITEMS[itemKey];
  const isMacaron = item.collection === 'Macarons';
  const customInput = isMacaron
    ? `<input type="text" id="custom-flavor-${itemKey}" placeholder="Describe your flavor..." style="display:none;flex:1;min-width:110px;padding:0.38rem 0.6rem;border-radius:8px;border:1px solid var(--blush-deep);background:var(--cream);font-family:var(--font-body);font-size:0.78rem;color:var(--dark);outline:none;" />`
    : '';
  const onchange = isMacaron
    ? `onchange="toggleCustomFlavor('${itemKey}', this)"`
    : '';
  return `<div class="atc-row" style="flex-wrap:wrap;gap:0.5rem;">
    <select class="flavor-select" id="flavor-${itemKey}" ${onchange}>${item.flavors.map(f => `<option>${f}</option>`).join('')}</select>
    ${customInput}
    <button class="atc-btn" id="atc-${itemKey}" onclick="addToCart('${itemKey}', this)">+ Add</button>
  </div>`;
}

function toggleCustomFlavor(key, select) {
  const customInput = document.getElementById('custom-flavor-' + key);
  if (!customInput) return;
  if (select.value === '✏️ Custom Flavor...') {
    customInput.style.display = 'block';
    customInput.focus();
  } else {
    customInput.style.display = 'none';
    customInput.value = '';
  }
}

function addToCart(key, btn) {
  const item = MENU_ITEMS[key];
  const flavorEl = document.getElementById('flavor-' + key);
  let flavor = flavorEl ? flavorEl.value : '';
  if (flavor === '✏️ Custom Flavor...') {
    const customEl = document.getElementById('custom-flavor-' + key);
    const customVal = customEl ? customEl.value.trim() : '';
    if (!customVal) {
      customEl.style.borderColor = '#e74c3c';
      customEl.placeholder = 'Please enter your flavor!';
      customEl.focus();
      return;
    }
    flavor = 'Custom: ' + customVal;
  }
  cart.push({ id: itemId++, key, name: item.name, collection: item.collection, price: item.price, flavor });
  btn.textContent = '✓ Added';
  btn.classList.add('added');
  setTimeout(() => { btn.textContent = '+ Add'; btn.classList.remove('added'); }, 1200);
  updateCartUI();
}

function addAddonToCart(key, btn) {
  const item = MENU_ITEMS[key];
  const label = key === 'addon-gf' ? 'Included (Free)' : 'Add-On';
  cart.push({ id: itemId++, key, name: item.name, collection: item.collection, price: item.price, flavor: label });
  btn.textContent = '✓ Added';
  btn.classList.add('added');
  setTimeout(() => { btn.textContent = '+ Add'; btn.classList.remove('added'); }, 1200);
  updateCartUI();
}

function removeFromCart(id) {
  cart = cart.filter(i => i.id !== id);
  updateCartUI();
}

function changeQty(id, delta) {
  // We store individual items — so add/remove
  if (delta < 0) {
    const idx = cart.findLastIndex ? cart.findLastIndex(i => i.id === id) : cart.map(i=>i.id).lastIndexOf(id);
    if (idx !== -1) cart.splice(idx, 1);
  }
  updateCartUI();
}

function updateCartUI() {
  const count = cart.length;
  document.getElementById('cartCount').textContent = count;
  document.getElementById('checkoutBtn').disabled = count === 0;

  const total = cart.reduce((s, i) => s + i.price, 0);
  document.getElementById('cartTotal').textContent = '$' + total.toFixed(2);

  // Group by id for display
  const groups = {};
  cart.forEach(item => {
    const k = item.key + '|' + item.flavor;
    if (!groups[k]) groups[k] = { ...item, qty: 0, ids: [] };
    groups[k].qty++;
    groups[k].ids.push(item.id);
  });

  const container = document.getElementById('cartItems');
  if (count === 0) {
    container.innerHTML = '<div class="cart-empty"><span>🌷</span>Your cart is empty.<br/>Add some beautiful treats!</div>';
    return;
  }
  container.innerHTML = Object.values(groups).map(g => `
    <div class="cart-item">
      <div class="cart-item-info">
        <div class="cart-item-name">${g.collection} — ${g.name}</div>
        <div class="cart-item-detail">Flavor: ${g.flavor}</div>
        <div class="cart-item-qty">
          <button class="qty-btn" onclick="removeOne('${g.key}','${g.flavor}')">−</button>
          <span class="qty-num">${g.qty}</span>
          <button class="qty-btn" onclick="addOneMore('${g.key}','${g.flavor}')">+</button>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.3rem;">
        <span class="cart-item-price">$${(g.price * g.qty).toFixed(2)}</span>
        <button class="cart-remove" onclick="removeGroup('${g.key}','${g.flavor}')">Remove</button>
      </div>
    </div>`).join('');
}

function removeOne(key, flavor) {
  const idx = cart.findIndex(i => i.key === key && i.flavor === flavor);
  if (idx !== -1) cart.splice(idx, 1);
  updateCartUI();
}
function addOneMore(key, flavor) {
  const item = MENU_ITEMS[key];
  cart.push({ id: itemId++, key, name: item.name, collection: item.collection, price: item.price, flavor });
  updateCartUI();
}
function removeGroup(key, flavor) {
  cart = cart.filter(i => !(i.key === key && i.flavor === flavor));
  updateCartUI();
}

// ══════════════════════════════════
//  CART DRAWER
// ══════════════════════════════════
function openCart() {
  document.getElementById('cartDrawer').classList.add('open');
  document.getElementById('cartOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeCart() {
  document.getElementById('cartDrawer').classList.remove('open');
  document.getElementById('cartOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

// ══════════════════════════════════
//  CHECKOUT MODAL
// ══════════════════════════════════
function openCheckout() {
  closeCart();
  const total = cart.reduce((s, i) => s + i.price, 0);
  const shipping = 12.99;
  const grandTotal = total + shipping;

  // Group for summary
  const groups = {};
  cart.forEach(item => {
    const k = item.key + '|' + item.flavor;
    if (!groups[k]) groups[k] = { ...item, qty: 0 };
    groups[k].qty++;
  });

  const summaryRows = Object.values(groups).map(g =>
    `<div class="co-summary-item"><span>${g.collection} — ${g.name} ×${g.qty} (${g.flavor})</span><span>$${(g.price*g.qty).toFixed(2)}</span></div>`
  ).join('');

  document.getElementById('checkoutBox').innerHTML = `
    <h3>Checkout 🌸</h3>
    <p class="checkout-sub">Fill in your details and we'll get your order on its way.</p>

    <div class="checkout-order-summary">
      ${summaryRows}
      <div class="co-summary-item"><span class="shipping-line">Shipping (standard)</span><span>$${shipping.toFixed(2)}</span></div>
      <div class="co-summary-total"><span>Total</span><span>$${grandTotal.toFixed(2)}</span></div>
    </div>

    <div class="co-form">
      <p class="checkout-section-title">Contact Information</p>
      <div class="co-row">
        <div class="co-group"><label>First Name</label><input type="text" id="co-fname" placeholder="Jane" /></div>
        <div class="co-group"><label>Last Name</label><input type="text" id="co-lname" placeholder="Smith" /></div>
      </div>
      <div class="co-group"><label>Email Address</label><input type="email" id="co-email" placeholder="jane@email.com" /></div>
      <div class="co-group"><label>Phone Number</label><input type="tel" id="co-phone" placeholder="(555) 000-0000" /></div>

      <p class="checkout-section-title">Shipping Address</p>
      <div class="co-group"><label>Street Address</label><input type="text" id="co-addr" placeholder="123 Bloom Lane" /></div>
      <div class="co-group"><label>Apartment / Suite (optional)</label><input type="text" id="co-addr2" placeholder="Apt 4B" /></div>
      <div class="co-row">
        <div class="co-group"><label>City</label><input type="text" id="co-city" placeholder="Las Vegas" /></div>
        <div class="co-group"><label>State</label>
          <select id="co-state">
            <option value="">Select state...</option>
            ${['AL','AK','AZ','AR','CA','CO','CT','DE','FL','GA','HI','ID','IL','IN','IA','KS','KY','LA','ME','MD','MA','MI','MN','MS','MO','MT','NE','NV','NH','NJ','NM','NY','NC','ND','OH','OK','OR','PA','RI','SC','SD','TN','TX','UT','VT','VA','WA','WV','WI','WY'].map(s=>`<option>${s}</option>`).join('')}
          </select>
        </div>
      </div>
      <div class="co-row">
        <div class="co-group"><label>ZIP Code</label><input type="text" id="co-zip" placeholder="89101" /></div>
        <div class="co-group"><label>Event / Delivery Date</label><input type="date" id="co-date" /></div>
      </div>

      <p class="checkout-section-title">Payment</p>
      <div class="co-group"><label>Card Number</label><input type="text" id="co-card" placeholder="•••• •••• •••• ••••" maxlength="19" oninput="fmtCard(this)" /></div>
      <div class="co-row">
        <div class="co-group"><label>Expiry (MM/YY)</label><input type="text" id="co-exp" placeholder="MM/YY" maxlength="5" oninput="fmtExp(this)" /></div>
        <div class="co-group"><label>CVV</label><input type="text" id="co-cvv" placeholder="•••" maxlength="4" /></div>
      </div>
      <div class="co-group"><label>Name on Card</label><input type="text" id="co-cardname" placeholder="Jane Smith" /></div>
    </div>

    <div class="checkout-actions">
      <button class="btn-back" onclick="closeCheckout()">← Back to Cart</button>
      <button class="btn-place-order" onclick="placeOrder()">Place Order 🌸</button>
    </div>
  `;

  document.getElementById('checkoutModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeCheckout() {
  document.getElementById('checkoutModal').classList.remove('open');
  document.body.style.overflow = '';
}

function fmtCard(el) {
  let v = el.value.replace(/\D/g,'').substring(0,16);
  el.value = v.match(/.{1,4}/g)?.join(' ') || v;
}
function fmtExp(el) {
  let v = el.value.replace(/\D/g,'');
  if (v.length >= 3) v = v.substring(0,2) + '/' + v.substring(2,4);
  el.value = v;
}

function placeOrder() {
  const required = ['co-fname','co-lname','co-email','co-phone','co-addr','co-city','co-state','co-zip','co-date','co-card','co-exp','co-cvv','co-cardname'];
  let valid = true;
  required.forEach(id => {
    const el = document.getElementById(id);
    if (!el || !el.value.trim()) {
      el && (el.style.borderColor = '#e74c3c');
      valid = false;
    } else {
      el.style.borderColor = '';
    }
  });
  if (!valid) return;

  const fname = document.getElementById('co-fname').value;
  document.getElementById('checkoutBox').innerHTML = `
    <div class="order-success">
      <div class="success-icon">🌸</div>
      <h4>Order Placed, ${fname}!</h4>
      <p>Thank you so much for your order. We've received it and will be in touch within 24 hours to confirm details and arrange delivery.<br/><br/>
      Questions? Call us at <a href="tel:8565627576" style="color:var(--blush-deep);">(856) 562-7576</a></p>
      <button class="btn-primary" onclick="finishOrder()" style="cursor:pointer;border:none;">Continue Shopping 🌷</button>
    </div>
  `;
  cart = [];
  updateCartUI();
}

function finishOrder() {
  closeCheckout();
}

// ══════════════════════════════════
//  INJECT ATC ROWS INTO MENU ITEMS
// ══════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  const mappings = [
    ['classic-mini7','classic-bq7','classic-bq12','classic-bq19','classic-box6','classic-box12','classic-box18','classic-box24','classic-mini24'],
    ['charm-bq7','charm-bq12','charm-bq19','charm-box6','charm-box12','charm-box18','charm-box24','charm-mini24'],
    ['intr-bq7','intr-bq12','intr-bq19','intr-box6','intr-box12','intr-box18','intr-box24','intr-mini24'],
    ['mac-6','mac-12','mac-30'],
    ['tower-4','tower-5','tower-6','tower-7','tower-8','tower-9','tower-10'],
  ];

  // All menu items in order across all cards
  const allKeys = mappings.flat();
  const menuItems = document.querySelectorAll('.menu-item');

  let ki = 0;
  menuItems.forEach(el => {
    const priceEl = el.querySelector('.menu-item-price');
    if (!priceEl || ki >= allKeys.length) return;
    const key = allKeys[ki++];
    const row = document.createElement('div');
    row.innerHTML = buildATCRow(key);
    el.insertAdjacentElement('afterend', row.firstElementChild);
  });
});
</script>

