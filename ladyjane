<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Lady Jane Cake Co. — Edible Art Inspired by Spring</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Dancing+Script:wght@500;700&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --blush: #f2c4ce;
    --blush-light: #fce8ed;
    --blush-deep: #e8a0b0;
    --cream: #fdf6ee;
    --cream-warm: #f9ecd8;
    --sage: #a8bfa8;
    --sage-light: #d4e4d4;
    --sage-deep: #7a9e7a;
    --lavender: #c9b8d8;
    --lavender-light: #ede5f5;
    --lavender-deep: #9d83bb;
    --gold: #c9a96e;
    --dark: #3a2d35;
    --dark-soft: #5c4a56;
    --mid: #8a7080;
    --white: #fffbf8;

    --font-serif: 'Cormorant Garamond', Georgia, serif;
    --font-script: 'Dancing Script', cursive;
    --font-body: 'Jost', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--cream);
    color: var(--dark);
    overflow-x: hidden;
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--cream); }
  ::-webkit-scrollbar-thumb { background: var(--blush-deep); border-radius: 3px; }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(253,246,238,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--blush);
    padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
    transition: box-shadow 0.3s;
  }
  nav.scrolled { box-shadow: 0 4px 24px rgba(58,45,53,0.08); }

  a.nav-logo { display: flex; align-items: center; text-decoration: none; }
  .nav-logo span { color: var(--blush-deep); }

  .nav-links {
    display: flex; gap: 2rem; list-style: none;
  }
  .nav-links a {
    font-family: var(--font-body);
    font-weight: 400; font-size: 0.82rem;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--dark-soft); text-decoration: none;
    transition: color 0.2s;
    position: relative;
  }
  .nav-links a::after {
    content: ''; position: absolute; bottom: -3px; left: 0; right: 0;
    height: 1px; background: var(--blush-deep);
    transform: scaleX(0); transition: transform 0.25s;
  }
  .nav-links a:hover { color: var(--blush-deep); }
  .nav-links a:hover::after { transform: scaleX(1); }

  .nav-cta {
    background: var(--blush-deep);
    color: var(--white) !important;
    padding: 0.5rem 1.2rem;
    border-radius: 30px;
    font-weight: 500 !important;
    transition: background 0.2s, transform 0.15s !important;
  }
  .nav-cta:hover { background: var(--dark-soft) !important; transform: translateY(-1px); }
  .nav-cta::after { display: none !important; }

  .nav-burger {
    display: none; flex-direction: column; gap: 5px;
    cursor: pointer; padding: 4px;
    background: none; border: none;
  }
  .nav-burger span {
    display: block; width: 24px; height: 2px;
    background: var(--dark); border-radius: 2px;
    transition: all 0.25s;
  }

  /* ─── MOBILE NAV ─── */
  .mobile-menu {
    display: none; position: fixed; inset: 0;
    background: var(--cream); z-index: 99;
    flex-direction: column; align-items: center; justify-content: center;
    gap: 2rem;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    font-family: var(--font-serif);
    font-size: 2rem; font-style: italic;
    color: var(--dark); text-decoration: none;
    transition: color 0.2s;
  }
  .mobile-menu a:hover { color: var(--blush-deep); }

  /* ─── HERO ─── */
  #home {
    min-height: 100vh;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(201,184,216,0.3) 0%, transparent 55%),
      radial-gradient(ellipse at 20% 80%, rgba(242,196,206,0.35) 0%, transparent 55%),
      radial-gradient(ellipse at 60% 70%, rgba(168,191,168,0.2) 0%, transparent 45%),
      var(--cream);
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    padding: 7rem 2rem 4rem;
    position: relative; overflow: hidden;
  }

  .hero-petals {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden;
  }
  .petal {
    position: absolute;
    opacity: 0;
    animation: petalFall linear infinite;
  }
  .petal svg { display: block; }

  @keyframes petalFall {
    0%   { transform: translateY(-60px) rotate(0deg); opacity: 0; }
    10%  { opacity: 0.7; }
    90%  { opacity: 0.5; }
    100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
  }

  .hero-content { position: relative; z-index: 2; max-width: 700px; }

  .hero-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.72rem; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--blush-deep);
    border: 1px solid var(--blush);
    padding: 0.35rem 1rem; border-radius: 20px;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.8s ease both;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 300; line-height: 1.05;
    color: var(--dark);
    margin-bottom: 0.5rem;
    animation: fadeUp 0.8s 0.15s ease both;
  }
  .hero-title em {
    font-style: italic; color: var(--blush-deep);
    display: block;
  }

  .hero-script {
    font-family: var(--font-script);
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    color: var(--sage-deep);
    margin-bottom: 1.8rem;
    animation: fadeUp 0.8s 0.25s ease both;
  }

  .hero-intro {
    font-size: 1rem; font-weight: 300; line-height: 1.75;
    color: var(--dark-soft); max-width: 520px; margin: 0 auto 2.5rem;
    animation: fadeUp 0.8s 0.35s ease both;
  }

  .hero-btns {
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
    animation: fadeUp 0.8s 0.45s ease both;
  }
  .btn-primary {
    background: var(--blush-deep);
    color: var(--white); border: none;
    padding: 0.9rem 2rem; border-radius: 40px;
    font-family: var(--font-body); font-size: 0.85rem;
    font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
    cursor: pointer; text-decoration: none;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(232,160,176,0.4);
  }
  .btn-primary:hover { background: var(--dark-soft); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(232,160,176,0.35); }

  .btn-outline {
    background: transparent;
    color: var(--dark); border: 1.5px solid var(--blush-deep);
    padding: 0.88rem 2rem; border-radius: 40px;
    font-family: var(--font-body); font-size: 0.85rem;
    font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
    cursor: pointer; text-decoration: none;
    transition: background 0.2s, color 0.2s, transform 0.15s;
  }
  .btn-outline:hover { background: var(--blush-light); color: var(--blush-deep); transform: translateY(-2px); }

  .hero-scroll {
    position: absolute; bottom: 2.5rem; left: 0; right: 0;
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    color: var(--mid); font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase;
    animation: fadeUp 1s 0.8s ease both;
  }
  .scroll-line {
    width: 1px; height: 40px; background: var(--blush);
    animation: scrollPulse 2s ease infinite;
  }
  @keyframes scrollPulse {
    0%,100% { opacity: 0.3; } 50% { opacity: 1; }
  }

  /* ─── FLORAL DIVIDER ─── */
  .floral-divider {
    display: flex; align-items: center; gap: 1rem;
    margin: 0 auto; max-width: 300px; padding: 1rem 0;
  }
  .floral-divider::before, .floral-divider::after {
    content: ''; flex: 1; height: 1px; background: var(--blush);
  }
  .floral-divider .bloom { font-size: 1.1rem; color: var(--blush-deep); }

  /* ─── SECTIONS ─── */
  section { padding: 6rem 2rem; }
  .section-inner { max-width: 1100px; margin: 0 auto; }

  .section-tag {
    font-family: var(--font-body);
    font-size: 0.7rem; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--blush-deep);
    margin-bottom: 0.6rem; display: block;
  }
  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 300; line-height: 1.1;
    color: var(--dark); margin-bottom: 1rem;
  }
  .section-title em { font-style: italic; color: var(--blush-deep); }
  .section-sub {
    font-size: 0.95rem; font-weight: 300; line-height: 1.8;
    color: var(--mid); max-width: 560px;
  }

  /* ─── TESTIMONIALS ─── */
  #testimonials {
    background:
      radial-gradient(ellipse at 30% 50%, rgba(201,184,216,0.18) 0%, transparent 60%),
      var(--blush-light);
    padding: 5rem 2rem;
  }
  .testimonials-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem; margin-top: 3rem;
  }
  .testimonial-card {
    background: var(--white); border-radius: 20px;
    padding: 2rem 1.8rem;
    box-shadow: 0 2px 20px rgba(58,45,53,0.06);
    position: relative; overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
    opacity: 0; transform: translateY(30px);
    transition: opacity 0.6s, transform 0.6s, box-shadow 0.3s;
  }
  .testimonial-card.visible { opacity: 1; transform: translateY(0); }
  .testimonial-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(58,45,53,0.1); }
  .testimonial-card::before {
    content: '\201C';
    font-family: var(--font-serif); font-size: 5rem; line-height: 1;
    color: var(--blush); position: absolute; top: 0.5rem; left: 1rem;
    opacity: 0.6;
  }
  .testimonial-card p {
    font-family: var(--font-serif); font-size: 1.05rem;
    font-style: italic; line-height: 1.7; color: var(--dark-soft);
    position: relative; z-index: 1;
  }
  .testimonial-stars {
    display: flex; gap: 3px; margin-bottom: 0.8rem;
  }
  .star { color: var(--gold); font-size: 0.85rem; }
  .testimonial-author {
    margin-top: 1rem; font-size: 0.78rem;
    font-weight: 500; letter-spacing: 0.08em;
    color: var(--blush-deep); text-transform: uppercase;
  }

  /* ─── ABOUT ─── */
  #about { background: var(--white); }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: center;
    margin-top: 3rem;
  }
  .about-visual {
    position: relative;
  }
  .about-img-main {
    width: 100%; aspect-ratio: 4/5; border-radius: 24px;
    background:
      radial-gradient(ellipse at 40% 40%, rgba(242,196,206,0.6) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 70%, rgba(168,191,168,0.4) 0%, transparent 50%),
      linear-gradient(135deg, var(--blush-light), var(--lavender-light));
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .about-img-main .img-placeholder {
    font-size: 6rem; opacity: 0.5;
  }
  .about-badge {
    position: absolute; bottom: -1.5rem; right: -1.5rem;
    width: 120px; height: 120px; border-radius: 50%;
    background: var(--blush-deep); color: var(--white);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; box-shadow: 0 4px 20px rgba(232,160,176,0.4);
  }
  .about-badge strong {
    font-family: var(--font-script); font-size: 2rem; line-height: 1;
  }
  .about-badge span { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.9; }

  .about-text { }
  .about-text p {
    font-size: 0.98rem; font-weight: 300; line-height: 1.85;
    color: var(--dark-soft); margin-bottom: 1.2rem;
  }
  .about-features {
    margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem;
  }
  .about-feature {
    display: flex; align-items: flex-start; gap: 1rem;
  }
  .about-feature-icon {
    width: 38px; height: 38px; border-radius: 50%;
    background: var(--blush-light); display: flex; align-items: center;
    justify-content: center; font-size: 1.1rem; flex-shrink: 0;
    margin-top: 2px;
  }
  .about-feature-text strong {
    display: block; font-size: 0.88rem; font-weight: 500;
    color: var(--dark); margin-bottom: 2px; letter-spacing: 0.03em;
  }
  .about-feature-text span {
    font-size: 0.82rem; color: var(--mid); font-weight: 300;
  }

  /* ─── MENU ─── */
  #menu {
    background:
      radial-gradient(ellipse at 80% 20%, rgba(242,196,206,0.2) 0%, transparent 50%),
      radial-gradient(ellipse at 10% 80%, rgba(201,184,216,0.2) 0%, transparent 50%),
      var(--cream);
  }
  .menu-tabs {
    display: flex; gap: 0.5rem; margin: 2.5rem 0;
    flex-wrap: wrap;
  }
  .menu-tab {
    padding: 0.6rem 1.4rem; border-radius: 30px;
    border: 1.5px solid var(--blush);
    background: transparent; color: var(--mid);
    font-family: var(--font-body); font-size: 0.8rem;
    font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
    cursor: pointer; transition: all 0.2s;
  }
  .menu-tab:hover { border-color: var(--blush-deep); color: var(--blush-deep); }
  .menu-tab.active { background: var(--blush-deep); border-color: var(--blush-deep); color: var(--white); }

  .menu-panel { display: none; }
  .menu-panel.active { display: block; }

  .menu-header {
    background: linear-gradient(135deg, var(--blush-light), var(--lavender-light));
    border-radius: 20px; padding: 2rem 2.5rem; margin-bottom: 2rem;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
  }
  .menu-header h3 {
    font-family: var(--font-serif); font-size: 1.8rem; font-weight: 300;
    font-style: italic; color: var(--dark);
  }
  .menu-header p { font-size: 0.85rem; font-weight: 300; color: var(--mid); margin-top: 0.3rem; }
  .menu-header .menu-icon { font-size: 2.5rem; }

  .menu-sections {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .menu-card {
    background: var(--white); border-radius: 18px;
    padding: 1.8rem; box-shadow: 0 2px 16px rgba(58,45,53,0.06);
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .menu-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(58,45,53,0.09); }
  .menu-card-title {
    font-family: var(--font-serif); font-size: 1.2rem; font-weight: 600;
    color: var(--dark); margin-bottom: 1.2rem; padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--blush); display: flex;
    align-items: center; justify-content: space-between;
  }
  .menu-card-title .collection-badge {
    font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
    background: var(--blush-light); color: var(--blush-deep);
    padding: 0.25rem 0.6rem; border-radius: 10px; font-family: var(--font-body);
  }
  .menu-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.55rem 0; border-bottom: 1px dashed rgba(242,196,206,0.5);
  }
  .menu-item:last-child { border-bottom: none; }
  .menu-item-name { font-size: 0.88rem; color: var(--dark-soft); font-weight: 300; }
  .menu-item-price {
    font-family: var(--font-serif); font-size: 0.95rem;
    font-weight: 600; color: var(--blush-deep);
  }
  .menu-note {
    font-size: 0.78rem; color: var(--mid); font-style: italic;
    margin-top: 0.8rem; padding-top: 0.8rem; border-top: 1px solid var(--blush-light);
  }

  /* flavors strip */
  .flavor-chips {
    display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1.5rem 0;
  }
  .flavor-chip {
    padding: 0.35rem 0.9rem; border-radius: 20px;
    background: var(--sage-light); color: var(--sage-deep);
    font-size: 0.78rem; font-weight: 500; letter-spacing: 0.04em;
  }

  /* addons */
  .addon-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem; margin-top: 1.5rem;
  }
  .addon-card {
    background: var(--white); border-radius: 16px; padding: 1.4rem 1.6rem;
    display: flex; align-items: center; gap: 1rem;
    box-shadow: 0 2px 14px rgba(58,45,53,0.05);
    border-left: 3px solid var(--blush-deep);
  }
  .addon-icon { font-size: 1.5rem; }
  .addon-label { font-size: 0.88rem; font-weight: 400; color: var(--dark-soft); }
  .addon-price { font-family: var(--font-serif); font-size: 0.95rem; font-weight: 600; color: var(--blush-deep); margin-top: 2px; }
  .addon-atc-btn {
    margin-left: auto; flex-shrink: 0;
    background: var(--blush-deep); color: var(--white);
    border: none; border-radius: 30px;
    padding: 0.45rem 1.1rem;
    font-family: var(--font-body); font-size: 0.78rem;
    font-weight: 500; letter-spacing: 0.06em;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .addon-atc-btn:hover { background: var(--dark-soft); transform: translateY(-1px); }
  .addon-atc-btn.added { background: var(--sage-deep); }
  .addon-card { cursor: default; transition: transform 0.2s, box-shadow 0.2s; }
  .addon-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(58,45,53,0.09); }

  /* ─── GALLERY ─── */
  #gallery { background: var(--white); }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto;
    gap: 1rem; margin-top: 3rem;
  }
  .gallery-item {
    border-radius: 16px; overflow: hidden;
    aspect-ratio: 1;
    background: linear-gradient(135deg, var(--blush-light), var(--lavender-light));
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; position: relative; overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .gallery-item:hover { transform: scale(1.02); box-shadow: 0 10px 32px rgba(58,45,53,0.15); }
  .gallery-item:nth-child(1) { grid-column: span 2; grid-row: span 2; aspect-ratio: unset; }
  .gallery-item:nth-child(5) { grid-column: span 2; aspect-ratio: 2/1; }
  .gallery-item .gallery-emoji {
    font-size: 3rem; opacity: 0.5; pointer-events: none;
    transition: transform 0.3s, opacity 0.3s;
  }
  .gallery-item:hover .gallery-emoji { transform: scale(1.1); opacity: 0.7; }
  .gallery-item:nth-child(1) { background: linear-gradient(135deg, var(--blush-light) 0%, rgba(242,196,206,0.7) 100%); }
  .gallery-item:nth-child(2) { background: linear-gradient(135deg, var(--lavender-light) 0%, rgba(201,184,216,0.5) 100%); }
  .gallery-item:nth-child(3) { background: linear-gradient(135deg, var(--sage-light) 0%, rgba(168,191,168,0.5) 100%); }
  .gallery-item:nth-child(4) { background: linear-gradient(135deg, var(--cream-warm) 0%, rgba(201,169,110,0.2) 100%); }
  .gallery-item:nth-child(5) { background: linear-gradient(135deg, var(--blush-light) 0%, var(--sage-light) 100%); }
  .gallery-item:nth-child(6) { background: linear-gradient(135deg, var(--lavender-light) 0%, rgba(242,196,206,0.4) 100%); }

  .gallery-overlay {
    position: absolute; inset: 0;
    background: rgba(58,45,53,0.5);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.3s;
  }
  .gallery-item:hover .gallery-overlay { opacity: 1; }
  .gallery-overlay span {
    color: var(--white); font-family: var(--font-serif);
    font-size: 0.9rem; font-style: italic; letter-spacing: 0.06em;
  }

  .gallery-upload-note {
    text-align: center; margin-top: 2rem;
    font-size: 0.82rem; color: var(--mid); font-style: italic;
  }

  /* ─── CUSTOM ─── */
  #custom {
    background:
      radial-gradient(ellipse at 60% 40%, rgba(201,184,216,0.25) 0%, transparent 55%),
      linear-gradient(180deg, var(--cream), var(--lavender-light));
    text-align: center;
  }
  .custom-inner { max-width: 680px; margin: 0 auto; }
  .custom-cards {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.2rem; margin: 3rem 0;
  }
  .custom-card {
    background: var(--white); border-radius: 18px;
    padding: 2rem 1.5rem;
    box-shadow: 0 2px 16px rgba(58,45,53,0.07);
    transition: transform 0.25s;
  }
  .custom-card:hover { transform: translateY(-4px); }
  .custom-card .custom-icon { font-size: 2.2rem; margin-bottom: 0.8rem; }
  .custom-card h4 {
    font-family: var(--font-serif); font-size: 1.1rem;
